}

model AufmassDatei {
  id         String   @id @default(cuid())
  aufmassId  String
  aufmass    Aufmass  @relation(fields: [aufmassId], references: [id], onDelete: Cascade)
  dateiTyp   String
  dateiName  String
  dateiUrl   String
  createdAt  DateTime @default(now())

  @@map("aufmass_dateien")
}

model AufmassPosition {
  id          String   @id @default(cuid())
  aufmassId   String
  aufmass     Aufmass  @relation(fields: [aufmassId], references: [id], onDelete: Cascade)
  position    Int      @default(0)
  bezeichnung String
  menge       Float    @default(0)
  einheit     String   @default("Stk")
  einzelpreis Float    @default(0)
  kategorie   String?
  raum        String?
  notizen     String?
  createdAt   DateTime @default(now())

  @@map("aufmass_positionen")
}

// ─── Einbau ─────────────────────────────────────────────────────

model EinbauPlan {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  titel     String
  dateiUrl  String
  dateiName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  markers       EinbauMarker[]
  planMaterials EinbauPlanMaterial[]

  @@map("einbau_plaene")
}

model EinbauPlanMaterial {
  id        String     @id @default(cuid())
  planId    String
  plan      EinbauPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  name      String
  menge     Float      @default(0)
  einheit   String     @default("Stk")
  createdAt DateTime   @default(now())

  @@map("einbau_plan_materialien")
}

model EinbauMarker {
  id          String   @id @default(cuid())
  planId      String
  plan        EinbauPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  xPercent    Float
  yPercent    Float
  beschreibung String
  mitarbeiterId String?
  mitarbeiterName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materialien EinbauMaterial[]

  @@map("einbau_markers")
}

model EinbauMaterial {
  id         String       @id @default(cuid())
  markerId   String
  marker     EinbauMarker @relation(fields: [markerId], references: [id], onDelete: Cascade)
  name       String
  menge      Float        @default(1)
  einheit    String       @default("Stk")
  isExtra    Boolean      @default(false)
  createdAt  DateTime     @default(now())

  @@map("einbau_materialien")
}

model SchlosserPruefConfig {
  id             String     @id @default(cuid())
  elementTyp     ElementTyp @unique
  intervallMonate Int       @default(12)
  vorlaufTage    Int        @default(30)
  pflicht        Boolean    @default(true)
  bezeichnung    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("schlosser_pruef_config")
}

// ─── KI-Provider ────────────────────────────────────────────────

model AiProvider {
  id          String   @id @default(cuid())
  name        String
  provider    String
  apiKey      String?
  apiUrl      String?
  model       String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  isLocal     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ai_providers")
}

// ─── Werkzeuge ──────────────────────────────────────────────────

enum ToolStatus {
  VERFUEGBAR
  ZUGEWIESEN
  IN_REPARATUR
  AUSGEMUSTERT
}

model Tool {
  id                 String        @id @default(cuid())
  name               String
  category           String?
  manufacturer       String?
  model              String?
  serialNumber       String?
  inventoryNumber    String?       @unique
  purchaseDate       DateTime?
  purchasePrice      Float?
  status             ToolStatus    @default(VERFUEGBAR)
  location           String?
  notes              String?
  imageUrl           String?
  inspectionInterval Int?          // in Monaten
  lastInspection     DateTime?
  nextInspection     DateTime?
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  assignments        ToolAssignment[]
  inspections        ToolInspection[]

  @@map("tools")
}

model ToolAssignment {
  id         String    @id @default(cuid())
  toolId     String
  tool       Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  assignedAt DateTime  @default(now())
  returnedAt DateTime?
  notes      String?

  @@map("tool_assignments")
}

model ToolInspection {
  id             String   @id @default(cuid())
  toolId         String
  tool           Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  inspectionDate DateTime @default(now())
  result         String?  // bestanden, maengel, nicht_bestanden
  inspector      String?
  notes          String?
  createdAt      DateTime @default(now())

  @@map("tool_inspections")
}

// ─── Schulungen ─────────────────────────────────────────────────

model TrainingType {
  id                String   @id @default(cuid())
  name              String
  description       String?
  intervalMonths    Int?     // Wiederholungsintervall in Monaten
  isRequired        Boolean  @default(true)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  records           TrainingRecord[]

  @@map("training_types")
}

model TrainingRecord {
  id               String       @id @default(cuid())
  trainingTypeId   String
  trainingType     TrainingType @relation(fields: [trainingTypeId], references: [id], onDelete: Cascade)
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  completedAt      DateTime
  expiresAt        DateTime?
  certificate      String?
  instructor       String?
  notes            String?
  createdAt        DateTime     @default(now())

  @@map("training_records")
}

// ─── Ausfälle ───────────────────────────────────────────────────

enum AbsenceType {
  KRANKHEIT
  UNFALL_ARBEIT
  UNFALL_PRIVAT
  KIND_KRANK
  ARZTBESUCH
  REHA
  QUARANTAENE
  SONSTIGES
}

model Absence {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  type        AbsenceType @default(KRANKHEIT)
  startDate   DateTime
  endDate     DateTime
  days        Int         @default(1)
  reason      String?
  notes       String?
  hasAttest   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("absences")
}

// ─── AZUBI ────────────────────────────────────────────────────────

model AzubiProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ausbildungsberuf  String
  ausbildungsBeginn DateTime?
  ausbildungsEnde   DateTime?
  ausbilderId       String?
  ausbilderName     String?
  berufsschule      String?
  klassenbezeichnung String?
  ausbildungsJahr   Int       @default(1)
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  schulTage         AzubiSchulTag[]
  pruefungen        AzubiPruefung[]

  @@map("azubi_profiles")
}

model AzubiSchulTag {
  id           String       @id @default(cuid())
  profileId    String
  profile      AzubiProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date         DateTime
  thema        String?
  notes        String?
  createdAt    DateTime     @default(now())

  @@map("azubi_schultage")
}

model AzubiPruefung {
  id           String       @id @default(cuid())
  profileId    String
  profile      AzubiProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title        String
  date         DateTime
  type         String?      // ZWISCHEN, ABSCHLUSS_TEIL1, ABSCHLUSS_TEIL2, GESELLENPRUEFUNG, SONSTIGE
  result       String?
  passed       Boolean?
  notes        String?
  createdAt    DateTime     @default(now())

  @@map("azubi_pruefungen")
}

enum ReportStatus {
  ENTWURF
  EINGEREICHT
  GENEHMIGT
  ABGELEHNT
}

model AzubiReport {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekNumber      Int
  year            Int
  startDate       DateTime
  endDate         DateTime
  betrieblich     String?
  schulisch       String?
  unterweisungen  String?
  stunden         Float?
  status          ReportStatus @default(ENTWURF)
  rejectionReason String?
  approvedAt      DateTime?
  approvedBy      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([userId, weekNumber, year])
  @@map("azubi_reports")
}

// ─── Termine / Appointments ──────────────────────

enum AppointmentStatus {
  GEPLANT
  BESTAETIGT
  IN_BEARBEITUNG
  ABGESCHLOSSEN
  ABGESAGT
}

enum AppointmentType {
  BERATUNG
  BESICHTIGUNG
  REPARATUR
  WARTUNG
  INSTALLATION
  NOTDIENST
  ABNAHME
  SONSTIGES
}

model Appointment {
  id              String            @id @default(cuid())
  title           String
  description     String?
  type            AppointmentType   @default(BERATUNG)
  status          AppointmentStatus @default(GEPLANT)
  startTime       DateTime
  endTime         DateTime
  allDay          Boolean           @default(false)
  location        String?
  street          String?
  zip             String?
  city            String?
  notes           String?

  customerId      String?
  customer        Customer?         @relation(fields: [customerId], references: [id])
  customerName    String?
  customerEmail   String?
  customerPhone   String?

  assignedToId    String?
  assignedTo      User?             @relation("TerminZugewiesen", fields: [assignedToId], references: [id])

  projectId       String?
  project         Project?          @relation(fields: [projectId], references: [id])

  bookingRequestId String?

  reminder        Boolean           @default(true)
  reminderMinutes Int               @default(60)
  color           String?

  createdById     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("appointments")
}

model BookingLink {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String?
  isActive        Boolean  @default(true)
  types           String?
  availableDays   String?  @default("{\"mon\":true,\"tue\":true,\"wed\":true,\"thu\":true,\"fri\":true,\"sat\":false,\"sun\":false}")
  startHour       Int      @default(8)
  endHour         Int      @default(17)
  slotDuration    Int      @default(60)
  bufferTime      Int      @default(15)
  maxDaysAhead    Int      @default(30)
  assignedToId    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requests        AppointmentRequest[]

  @@map("booking_links")
}

model AppointmentRequest {
  id              String            @id @default(cuid())
  bookingLinkId   String
  bookingLink     BookingLink       @relation(fields: [bookingLinkId], references: [id])
  customerName    String
  customerEmail   String?
  customerPhone   String?
  message         String?
  type            AppointmentType   @default(BERATUNG)
  preferredDate   DateTime
  preferredTime   String?
  alternativeDate DateTime?
  status          String            @default("NEU")
  appointmentId   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("appointment_requests")
}

// ─── Vereinbarungen / Agreements ─────────────────

enum AgreementStatus {
  ENTWURF
  AKTIV
  ABGESCHLOSSEN
  GEKUENDIGT
}

model Agreement {
  id          String          @id @default(cuid())
  title       String
  status      AgreementStatus @default(ENTWURF)
  isTemplate  Boolean         @default(false)
  customerId  String?
  customer    Customer?       @relation(fields: [customerId], references: [id])
  projectId   String?
  project     Project?        @relation(fields: [projectId], references: [id])
  blocks      String?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("agreements")
}
