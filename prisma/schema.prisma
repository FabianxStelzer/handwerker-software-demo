generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  BAULEITER
  MITARBEITER
}

enum CustomerType {
  PRIVAT
  GESCHAEFT
}

enum ProjectStatus {
  PLANUNG
  AKTIV
  PAUSIERT
  ABGESCHLOSSEN
  STORNIERT
}

enum TaskPriority {
  HOCH
  MITTEL
  NIEDRIG
}

enum TaskStatus {
  OFFEN
  IN_BEARBEITUNG
  ERLEDIGT
}

enum OrderStatus {
  ENTWURF
  AUSSTEHEND
  BESTAETIGT
  ABGESCHLOSSEN
  STORNIERT
}

enum QuotationStatus {
  ENTWURF
  VERSENDET
  ANGENOMMEN
  ABGELEHNT
  ABGELAUFEN
}

enum InvoiceStatus {
  ENTWURF
  VERSENDET
  BEZAHLT
  UEBERFAELLIG
}

enum VacationStatus {
  AUSSTEHEND
  GENEHMIGT
  ABGELEHNT
}

enum MaterialUnit {
  STUECK
  METER
  QUADRATMETER
  KUBIKMETER
  KILOGRAMM
  LITER
  PALETTE
  PAUSCHAL
  STUNDE
}

// ─── Auth & Users ────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole  @default(MITARBEITER)
  phone          String?
  avatarUrl      String?
  position       String?
  street         String?
  zip            String?
  city           String?
  hireDate       DateTime?
  salary         Float?
  vacationDays   Int       @default(30)
  language       String    @default("de")
  permissions    String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  timeEntries      TimeEntry[]
  vacationRequests VacationRequest[]
  chatMessages     ProjectChatMessage[]
  notifications    Notification[]
  payslips         Payslip[]
  documents        EmployeeDocument[]
  aiConversations  AIConversation[]

  zugewieseneAufgaben  SchlosserAufgabe[]  @relation("AufgabeZugewiesen")
  erstellteAufgaben    SchlosserAufgabe[]  @relation("AufgabeErstellt")
  aufgabenKommentare   SchlosserAufgabeKommentar[]
  notizen              UserNote[]
  angefordertesMaterial ProjectMaterial[] @relation("MaterialAngefordert")
  vehicleAssignments   VehicleAssignment[]
  licenseUploads       LicenseUpload[]
  toolAssignments      ToolAssignment[]
  trainingRecords      TrainingRecord[]
  absences             Absence[]
  azubiProfile         AzubiProfile?
  azubiReports         AzubiReport[]
  appointments         Appointment[]       @relation("TerminZugewiesen")

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  @@map("sessions")
}

model CompanySettings {
  id                 String   @id @default(cuid())
  name               String?
  street             String?
  zip                String?
  city               String?
  phone              String?
  email              String?
  taxId              String?
  vatId              String?
  lunchBreakMinutes  Int      @default(30)
  workHoursPerDay    Float    @default(8)
  catalogApiKey      String?
  logoUrl            String?
  website            String?
  fax                String?
  instagram          String?
  hourlyRate         Float    @default(55)
  gocardlessSecretId  String?
  gocardlessSecretKey String?
  aiChatProviderId    String?
  aiAufmassProviderId String?
  aiChatSystemPrompt  String?
  aiAufmassSystemPrompt String?

  preisAufBelegen     String?   // netto, brutto, umsatzsteuerfrei
  unternehmenstyp     String?   // einzelunternehmen, gmbh, gbr, ug, ohg, kg, ag, ev, freelancer
  gewinnermittlung    String?   // euer, bilanzierung
  bundesland          String?
  besteuerung         String?   // ist, soll
  euUmsatzsteuer      String?   // deutsch, eu-zielland
  pvNullsteuer        Boolean   @default(false)
  kontenrahmen        String?   // skr03, skr04
  hatSteuerberater    Boolean   @default(false)
  kanzleiAnbindung    String?   // keine, datev, addison, agenda

  emailAbsenderName   String?
  emailAbsenderAdresse String?
  emailVorlagen       String?   // JSON: { rechnung, angebot, ... }

  nkKundenNaechster   Int       @default(10064)
  nkLieferantenNaechster Int    @default(70089)
  nkBelege            String?   // JSON: { rechnungen: { kuerzel, freifeld, naechster, mindestlaenge }, ... }

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("company_settings")
}

// ─── Customers ───────────────────────────────────────────────────

model Customer {
  id              String       @id @default(cuid())
  customerNumber  String?      @unique
  type            CustomerType @default(PRIVAT)
  company         String?
  firstName       String
  lastName        String
  email           String?
  phone           String?
  street          String?
  zip             String?
  city            String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  projects         Project[]
  orders           Order[]
  quotations       Quotation[]
  schlosserObjekte SchlosserObjekt[]
  deliveryNotes    DeliveryNote[]
  appointments     Appointment[]
  agreements       Agreement[]

  @@map("customers")
}

// ─── Projects ────────────────────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  projectNumber String        @unique
  name          String
  description   String?
  status        ProjectStatus @default(PLANUNG)
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])

  siteStreet    String?
  siteZip       String?
  siteCity      String?

  startDate     DateTime?
  endDate       DateTime?
  plannedHours  Float?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  entries       ProjectEntry[]
  documents     ProjectDocument[]
  tasks         ProjectTask[]
  chatMessages  ProjectChatMessage[]
  materials     ProjectMaterial[]
  blueprints    ProjectBlueprint[]
  timeEntries   TimeEntry[]
  orders        Order[]
  quotations    Quotation[]
  expenses       Expense[]
  deliveryNotes  DeliveryNote[]
  regieberichte  Regiebericht[]
  aufmasse       Aufmass[]      @relation("ProjectAufmasse")
  einbauPlaene   EinbauPlan[]
  staffAssignments ProjectStaffAssignment[]
  phases           ProjectPhase[]
  appointments     Appointment[]
  agreements       Agreement[]

  @@map("projects")
}

model ProjectPhase {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  startDate       DateTime
  endDate         DateTime?
  color           String?
  category        String?   // BAUHERR, EIGENBETRIEB, SUBFIRMA, MEILENSTEIN
  assignedTo      String?   // Mitarbeiter-IDs (kommagetrennt) oder Firmenname
  vehicleIds      String?   // Fahrzeug-IDs (kommagetrennt)
  subcontractor   String?   // Name der Subfirma
  groupName       String?   // Gruppierung z.B. "Rohbau", "Dachstuhl", Subfirmenname
  isMilestone     Boolean   @default(false)
  status          String    @default("GEPLANT") // GEPLANT, IN_ARBEIT, ABGESCHLOSSEN, VERZOEGERT
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("project_phases")
}

model ProjectStaffAssignment {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  vehicleId   String?
  role        String?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  createdAt   DateTime  @default(now())

  @@map("project_staff_assignments")
}

model ProjectEntry {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  content     String
  date        DateTime @default(now())
  attachments ProjectEntryAttachment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("project_entries")
}

model ProjectEntryAttachment {
  id        String       @id @default(cuid())
  entryId   String
  entry     ProjectEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String
  createdAt DateTime     @default(now())

  @@map("project_entry_attachments")
}

model ProjectDocument {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  fileUrl   String
  fileType  String
  folder    String   @default("Allgemein")
  color     String   @default("#3B82F6")
  fileSize  Int?
  createdAt DateTime @default(now())

  @@map("project_documents")
}

model ProjectTask {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  priority    TaskPriority @default(MITTEL)
  status      TaskStatus   @default(OFFEN)
  dueDate     DateTime?
  assigneeId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("project_tasks")
}

model ProjectChatMessage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@map("project_chat_messages")
}

model ProjectMaterial {
  id              String          @id @default(cuid())
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  catalogMaterialId String?
  catalogMaterial CatalogMaterial? @relation(fields: [catalogMaterialId], references: [id])
  name            String
  description     String?
  imageUrl        String?
  unit            MaterialUnit    @default(STUECK)
  quantityPlanned Float           @default(0)
  quantityUsed    Float           @default(0)
  pricePerUnit    Float           @default(0)
  notes           String?
  isAdditional    Boolean         @default(false)
  isInstalled     Boolean         @default(false)
  requestedById   String?
  requestedBy     User?           @relation("MaterialAngefordert", fields: [requestedById], references: [id])
  requestedAt     DateTime?
  approvedAt      DateTime?
  installedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("project_materials")
}

model ProjectBlueprint {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  fileUrl   String
  folder    String   @default("Allgemein")
  createdAt DateTime @default(now())

  @@map("project_blueprints")
}

// ─── Catalog ─────────────────────────────────────────────────────

model CatalogMaterial {
  id              String       @id @default(cuid())
  name            String
  description     String?
  imageUrl        String?
  unit            MaterialUnit @default(STUECK)
  pricePerUnit    Float        @default(0)
  weight          Float?
  format          String?
  thermalValue    Float?
  minSlope        Float?
  category        String?

  artikelNr       String?
  ean             String?
  taxRate         Float        @default(19)
  purchasePrice   Float?
  margin          Float?
  minStock        Float?
  currentStock    Float?
  invoiceText     String?
  notes           String?
  isActive        Boolean      @default(true)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  projectMaterials ProjectMaterial[]
  orderItems       OrderItem[]
  quotationItems   QuotationItem[]

  @@map("catalog_materials")
}

model CatalogService {
  id           String       @id @default(cuid())
  name         String
  description  String?
  unit         MaterialUnit @default(STUNDE)
  pricePerUnit Float        @default(0)
  category     String?

  artikelNr    String?
  taxRate      Float        @default(19)
  duration     Float?
  invoiceText  String?
  notes        String?
  isActive     Boolean      @default(true)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  orderItems     OrderItem[]
  quotationItems QuotationItem[]

  @@map("catalog_services")
}

// ─── Quotations (Angebote) ───────────────────────────────────────

model Quotation {
  id            String            @id @default(cuid())
  quotationNumber String          @unique
  customerId    String
  customer      Customer         @relation(fields: [customerId], references: [id])
  projectId     String?
  project       Project?         @relation(fields: [projectId], references: [id])
  status        QuotationStatus   @default(ENTWURF)
  validUntil    DateTime?
  notes         String?
  netTotal      Float             @default(0)
  taxRate       Float             @default(19)
  taxAmount     Float             @default(0)
  grossTotal    Float             @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  items       QuotationItem[]
  order       Order?

  @@map("quotations")
}

model QuotationItem {
  id                String           @id @default(cuid())
  quotationId       String
  quotation         Quotation        @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  catalogMaterialId String?
  catalogMaterial   CatalogMaterial? @relation(fields: [catalogMaterialId], references: [id])
  catalogServiceId  String?
  catalogService    CatalogService?  @relation(fields: [catalogServiceId], references: [id])
  description       String
  unit              MaterialUnit     @default(STUECK)
  quantity          Float            @default(1)
  pricePerUnit      Float            @default(0)
  total             Float            @default(0)
  position          Int              @default(0)
  createdAt         DateTime         @default(now())

  @@map("quotation_items")
}

// ─── Orders & Invoices ───────────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  quotationId   String?       @unique
  quotation     Quotation?    @relation(fields: [quotationId], references: [id])
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id])
  status        OrderStatus   @default(ENTWURF)
  notes         String?
  netTotal      Float         @default(0)
  taxRate       Float         @default(19)
  taxAmount     Float         @default(0)
  grossTotal    Float         @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  items    OrderItem[]
  invoice  Invoice?

  @@map("orders")
}

model OrderItem {
  id                String           @id @default(cuid())
  orderId           String
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  catalogMaterialId String?
  catalogMaterial   CatalogMaterial? @relation(fields: [catalogMaterialId], references: [id])
  catalogServiceId  String?
  catalogService    CatalogService?  @relation(fields: [catalogServiceId], references: [id])
  description       String
  unit              MaterialUnit     @default(STUECK)
  quantity          Float            @default(1)
  pricePerUnit      Float            @default(0)
  total             Float            @default(0)
  position          Int              @default(0)
  createdAt         DateTime         @default(now())

  @@map("order_items")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id])
  status        InvoiceStatus @default(ENTWURF)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  paidDate      DateTime?
  netTotal      Float         @default(0)
  taxRate       Float         @default(19)
  taxAmount     Float         @default(0)
  grossTotal    Float         @default(0)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id           String       @id @default(cuid())
  invoiceId    String
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description  String
  unit         MaterialUnit @default(STUECK)
  quantity     Float        @default(1)
  pricePerUnit Float        @default(0)
  total        Float        @default(0)
  position     Int          @default(0)
  createdAt    DateTime     @default(now())

  @@map("invoice_items")
}

// ─── Buchhaltung (Expenses, Vendors) ──────────────────────────────

model Vendor {
  id            String   @id @default(cuid())
  vendorNumber  String?  @unique
  name          String
  taxId         String?
  vatId         String?
  street        String?
  zip           String?
  city          String?
  email         String?
  phone         String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  expenses         Expense[]
  incomingInvoices IncomingInvoice[]

  @@map("vendors")
}

enum IncomingInvoiceStatus {
  OFFEN
  BEZAHLT
  UEBERFAELLIG
}

model IncomingInvoice {
  id            String                 @id @default(cuid())
  vendorId      String
  vendor        Vendor                 @relation(fields: [vendorId], references: [id])
  referenceNo   String                 // Rechnungsnummer des Lieferanten
  date          DateTime
  dueDate       DateTime?
  grossAmount   Float                  @default(0)
  status        IncomingInvoiceStatus   @default(OFFEN)
  paidDate      DateTime?
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@map("incoming_invoices")
}

model DeliveryNote {
  id          String    @id @default(cuid())
  noteNumber  String    @unique
  date        DateTime  @default(now())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items DeliveryNoteItem[]

  @@map("delivery_notes")
}

model DeliveryNoteItem {
  id          String       @id @default(cuid())
  deliveryId  String
  delivery    DeliveryNote @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  description String
  quantity    Float        @default(1)
  unit        MaterialUnit @default(STUECK)
  createdAt   DateTime     @default(now())

  @@map("delivery_note_items")
}

model Expense {
  id          String        @id @default(cuid())
  date        DateTime
  category    String        // z.B. Material, Fahrtkosten, Werkzeug, Sonstiges
  description String
  amount      Float
  taxRate     Float         @default(19)
  taxAmount   Float         @default(0)
  grossAmount Float         @default(0)
  vendor      String?       // Freitext, falls kein Vendor verknüpft
  vendorId    String?
  vendorRef   Vendor?       @relation(fields: [vendorId], references: [id])
  receiptUrl  String?
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("expenses")
}

model TimeEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id])
  date       DateTime
  startTime  String
  endTime    String?
  breakMin   Int      @default(0)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("time_entries")
}

// ─── HR ──────────────────────────────────────────────────────────

model VacationRequest {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  startDate DateTime
  endDate   DateTime
  days      Int
  reason    String?
  status    VacationStatus @default(AUSSTEHEND)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("vacation_requests")
}

model Payslip {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  month     Int
  year      Int
  fileUrl   String
  fileName  String
  createdAt DateTime @default(now())

  @@map("payslips")
}

model EmployeeDocument {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now())

  @@map("employee_documents")
}

model UserNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String   @default("")
  color     String   @default("#FEF3C7")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_notes")
}

// ─── Regieberichte ──────────────────────────────────────────────

enum RegieberichtStatus {
  ENTWURF
  ABGESCHLOSSEN
  UNTERSCHRIEBEN
  RECHNUNG_ERSTELLT
}

model Regiebericht {
  id               String              @id @default(cuid())
  berichtNummer    Int                 @unique
  projectId        String
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  datum            DateTime            @default(now())
  durchgefuehrteArbeiten String?
  status           RegieberichtStatus  @default(ENTWURF)
  unterschriftUrl  String?
  createdById      String
  invoiceId        String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  mitarbeiter RegieMitarbeiter[]
  materialien RegieMaterial[]

  @@map("regieberichte")
}

model RegieMitarbeiter {
  id              String       @id @default(cuid())
  regieberichtId  String
  regiebericht    Regiebericht @relation(fields: [regieberichtId], references: [id], onDelete: Cascade)
  userId          String
  name            String
  stunden         Float        @default(0)
  createdAt       DateTime     @default(now())

  @@map("regie_mitarbeiter")
}

model RegieMaterial {
  id              String       @id @default(cuid())
  regieberichtId  String
  regiebericht    Regiebericht @relation(fields: [regieberichtId], references: [id], onDelete: Cascade)
  name            String
  einheit         String       @default("Stk")
  menge           Float        @default(1)
  einzelpreis     Float        @default(0)
  createdAt       DateTime     @default(now())

  @@map("regie_materialien")
}

// ─── Banking ────────────────────────────────────────────────────

model BankConnection {
  id              String   @id @default(cuid())
  institutionId   String
  institutionName String
  institutionLogo String?
  requisitionId   String   @unique
  status          String   @default("CR")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts BankAccount[]

  @@map("bank_connections")
}

model BankAccount {
  id               String    @id @default(cuid())
  connectionId     String
  connection       BankConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  externalId       String    @unique
  iban             String?
  name             String
  balanceAmount    Float     @default(0)
  balanceCurrency  String    @default("EUR")
  balanceUpdatedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  transactions BankTransaction[]

  @@map("bank_accounts")
}

model BankTransaction {
  id           String    @id @default(cuid())
  accountId    String
  account      BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  externalId   String?
  amount       Float
  currency     String    @default("EUR")
  bookingDate  DateTime
  valueDate    DateTime?
  debtorName   String?
  creditorName String?
  description  String?
  invoiceId    String?
  expenseId    String?
  createdAt    DateTime  @default(now())

  @@map("bank_transactions")
}

// ─── Dokumentvorlagen ────────────────────────────────────────────

enum DocumentTemplateType {
  RECHNUNG
  ANGEBOT
  REGIEBERICHT
}

model DocumentTemplate {
  id        String               @id @default(cuid())
  type      DocumentTemplateType
  name      String
  html      String
  isDefault Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@map("document_templates")
}

