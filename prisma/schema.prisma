// ─── Schlosser: Prüf- & Wartungsmanagement ──────────────────────

enum ElementTyp {
  TUER
  FENSTER
  TOR
  GELAENDER
  ZAUN
  SCHLOSS
  FLUCHTWEG
  BRANDSCHUTZTUER
  SONSTIGES
}

enum PruefErgebnis {
  BESTANDEN
  MAENGEL
  NICHT_BESTANDEN
}

enum MangelSchwere {
  LEICHT
  MITTEL
  SCHWER
  KRITISCH
}

enum ObjektStatus {
  OK
  WARTUNG_FAELLIG
  REPARATUR_NOETIG
  NACHPRUEFUNG_OFFEN
  PRUEFUNG_UEBERFAELLIG
}

model SchlosserObjekt {
  id           String       @id @default(cuid())
  customerId   String
  customer     Customer     @relation(fields: [customerId], references: [id])
  name         String
  street       String?
  zip          String?
  city         String?
  description  String?
  planFileName String?
  planUrl      String?
  status       ObjektStatus @default(OK)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  elemente SchlosserElement[]
  aufgaben SchlosserAufgabe[]
  bilder   SchlosserObjektBild[]
  plaene   SchlosserObjektPlan[]

  @@map("schlosser_objekte")
}

model SchlosserObjektPlan {
  id           String          @id @default(cuid())
  objektId     String
  objekt       SchlosserObjekt @relation(fields: [objektId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  titel        String?
  beschreibung String?
  createdAt    DateTime        @default(now())

  @@map("schlosser_objekt_plaene")
}

model SchlosserElement {
  id           String     @id @default(cuid())
  objektId     String
  objekt       SchlosserObjekt @relation(fields: [objektId], references: [id], onDelete: Cascade)
  typ          ElementTyp @default(TUER)
  bezeichnung  String
  standort     String?
  hersteller   String?
  baujahr      Int?
  seriennummer String?
  notizen      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  pruefungen SchlosserPruefung[]
  bilder     SchlosserElementBild[]

  @@map("schlosser_elemente")
}

model SchlosserPruefung {
  id          String        @id @default(cuid())
  elementId   String
  element     SchlosserElement @relation(fields: [elementId], references: [id], onDelete: Cascade)
  datum       DateTime      @default(now())
  pruefer     String?
  ergebnis    PruefErgebnis @default(BESTANDEN)
  notizen     String?
  naechstePruefung DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  maengel SchlosserMangel[]
  texteintraege SchlosserPruefungText[]

  @@map("schlosser_pruefungen")
}

model SchlosserPruefungText {
  id         String       @id @default(cuid())
  pruefungId String
  pruefung   SchlosserPruefung @relation(fields: [pruefungId], references: [id], onDelete: Cascade)
  text       String
  createdAt  DateTime     @default(now())

  @@map("schlosser_pruefung_texte")
}

model SchlosserMangel {
  id           String        @id @default(cuid())
  pruefungId   String
  pruefung     SchlosserPruefung @relation(fields: [pruefungId], references: [id], onDelete: Cascade)
  beschreibung String
  schwere      MangelSchwere @default(MITTEL)
  fotoUrl      String?
  fotoName     String?
  fotoUrls     Json?         // [{url, fileName}, ...] für mehrere Bilder
  behoben      Boolean       @default(false)
  behobenAm    DateTime?
  behobenVon   String?
  behobenNotiz String?
  notizen      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("schlosser_maengel")
}

enum AufgabeTyp {
  REPARATUR
  PRUEFUNG
  WARTUNG
  SONSTIGES
}

enum AufgabePrioritaet {
  NIEDRIG
  NORMAL
  HOCH
  DRINGEND
}

enum AufgabeStatus {
  OFFEN
  IN_ARBEIT
  WARTE_AUF_MATERIAL
  ERLEDIGT
  ABGENOMMEN
}

model SchlosserAufgabe {
  id            String            @id @default(cuid())
  objektId      String
  objekt        SchlosserObjekt   @relation(fields: [objektId], references: [id], onDelete: Cascade)
  elementId     String?
  mangelId      String?
  typ           AufgabeTyp        @default(REPARATUR)
  titel         String
  beschreibung  String?
  prioritaet    AufgabePrioritaet @default(NORMAL)
  status        AufgabeStatus     @default(OFFEN)
  zugewiesenAn  String?
  zugewiesen    User?             @relation("AufgabeZugewiesen", fields: [zugewiesenAn], references: [id])
  erstelltVon   String
  ersteller     User              @relation("AufgabeErstellt", fields: [erstelltVon], references: [id])
  faelligAm     DateTime?
  erledigtAm    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  kommentare SchlosserAufgabeKommentar[]

  @@map("schlosser_aufgaben")
}

model SchlosserAufgabeKommentar {
  id         String   @id @default(cuid())
  aufgabeId  String
  aufgabe    SchlosserAufgabe @relation(fields: [aufgabeId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  text       String
  fotoUrl    String?
  fotoName   String?
  createdAt  DateTime @default(now())

  @@map("schlosser_aufgabe_kommentare")
}

model SchlosserObjektBild {
  id         String          @id @default(cuid())
  objektId   String
  objekt     SchlosserObjekt @relation(fields: [objektId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  beschreibung String?
  createdAt  DateTime        @default(now())

  @@map("schlosser_objekt_bilder")
}

model SchlosserElementBild {
  id         String           @id @default(cuid())
  elementId  String
  element    SchlosserElement @relation(fields: [elementId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  beschreibung String?
  createdAt  DateTime         @default(now())

  @@map("schlosser_element_bilder")
}

// ─── Aufmaß ─────────────────────────────────────────────────────

enum AufmassStatus {
  ENTWURF
  IN_BEARBEITUNG
  FERTIG
}

model Aufmass {
  id           String        @id @default(cuid())
  titel        String
  beschreibung String?
  status       AufmassStatus @default(ENTWURF)
  kiAnweisung  String?
  kiErgebnis   String?
  projectId    String?
  project      Project?      @relation("ProjectAufmasse", fields: [projectId], references: [id], onDelete: SetNull)
  createdById  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  dateien  AufmassDatei[]
  positionen AufmassPosition[]

